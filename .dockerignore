# Dependencies — installed fresh inside Docker
node_modules
npm-debug.log*

# Lock file — we use npm install, not npm ci
package-lock.json

# Angular build output (rebuilt inside Docker)
dist

# Angular cache
.angular

# Dev tools & IDE
.vscode
.git
.gitignore

# OS files
.DS_Store
Thumbs.db
*.log

# Test files
**/*.spec.ts
coverage

# Local env files
.env
.env.*

# Scripts only needed locally
scripts

# Docker files themselves (not needed inside container)
Dockerfile
docker-compose.yml
.dockerignore
