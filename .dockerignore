# Dependencies - never copy these, they get installed in the Docker build
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Angular build output (built fresh inside Docker)
dist

# Angular cache
.angular

# Dev tools & IDE
.vscode
.git
.gitignore

# Temporary / OS files
.DS_Store
Thumbs.db
*.log

# Test files
**/*.spec.ts
coverage

# Local env files
.env
.env.*

# Docker files themselves
Dockerfile
docker-compose.yml
.dockerignore

# Scripts only needed locally
scripts
